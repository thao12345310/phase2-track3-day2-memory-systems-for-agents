# Required
OPENAI_API_KEY=sk-...

# Optional - Redis for long-term profile (defaults to dict/JSON if not set)
REDIS_URL=redis://localhost:6379/0

# Optional - Model config
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=2048

# Memory config
SHORT_TERM_WINDOW=10
MEMORY_TOKEN_BUDGET=3000
SEMANTIC_TOP_K=3
